USE_LOCAL_LLM=False

# Основная (мощная) модель для сложных задач (Сценарист, Планировщик)
LLM__BASE_URL=https://api.openai.com/v1
LLM__API_KEY=sk-your-openai-api-key
LLM__MODEL_NAME=gpt-4o

# Дешевая модель для сжатия текстов и линтера
CHEAP_LLM__BASE_URL=https://api.openai.com/v1
CHEAP_LLM__API_KEY=sk-your-openai-api-key
CHEAP_LLM__MODEL_NAME=gpt-4o-mini

# Настройки для локальной модели (если USE_LOCAL_LLM=True)
LOCAL_LLM__BASE_URL=http://localhost:11434/v1
LOCAL_LLM__API_KEY=ollama
LOCAL_LLM__MODEL_NAME=llama3

# Настройки агента-поисковика
RESEARCHERS__RECURSION_LIMIT=40

# Токен Telegram-бота (получить у @BotFather)
TELEGRAM__TOKEN=123456789:ABCDefghIJKLmnopQRSTuvwxYZ
